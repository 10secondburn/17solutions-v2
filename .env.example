# 17solutions — Environment Variables
# ====================================
#
# FÜR VERCEL: Diese Werte in Vercel → Settings → Environment Variables eintragen.
# FÜR LOKAL:  Kopiere diese Datei zu .env.local und passe die Werte an.

# === Datenbank (Neon PostgreSQL) ===
# Neon: https://neon.tech → Projekt erstellen → Connection String kopieren
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/seventeensolutions?sslmode=require

# === NextAuth ===
# NEXTAUTH_URL = Deine Domain (lokal: http://localhost:3000, production: https://app.17solutions.de)
NEXTAUTH_URL=https://app.17solutions.de
# Zufälliger String, mind. 32 Zeichen (openssl rand -base64 32)
NEXTAUTH_SECRET=

# === Anthropic API ===
ANTHROPIC_API_KEY=sk-ant-...

# === Admin Setup ===
# Der Admin-User wird beim Seeden erstellt (npm run db:seed)
ADMIN_EMAIL=f100r@me.com
ADMIN_PASSWORD=changeme123
